{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "KeyHeatMap",
    "version": "0.7.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true,
        "open": true,
        "save": true
      },
      "fs": {
        "all": true,
        "scope": [
          "**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.keyheat-map.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/512x512.png",
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "resources": [],
      "copyright": "",
      "category": "Utility",
      "shortDescription": "Keyboard & Mouse Heatmap Tracker",
      "longDescription": "A cross-platform keyboard and mouse heatmap desktop application for programmers and gamers.",
      "deb": {
        "depends": [],
        "files": {}
      },
      "rpm": {
        "depends": [],
        "release": "1"
      }
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "键盘侠 - KeyHeat Map",
        "width": 1100,
        "height": 750,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  }
}
